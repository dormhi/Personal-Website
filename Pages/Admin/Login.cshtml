@page
@model PersonalWebSite.Pages.Admin.LoginModel
@{
    ViewData["Title"] = "Admin Login";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card bg-dark border border-secondary shadow-lg text-light">
                <div class="card-header bg-primary text-white text-center py-4">
                    <h3 class="mb-0"><i class="fa-solid fa-lock"></i> Admin Login</h3>
                </div>
                <div class="card-body p-4">
                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        
                        <div class="mb-3">
                            <label asp-for="Username" class="form-label text-muted">Username</label>
                            <input asp-for="Username" class="form-control bg-dark text-light border-secondary" placeholder="Enter username" required />
                            <span asp-validation-for="Username" class="text-danger"></span>
                        </div>
                        
                        <div class="mb-3">
                            <label asp-for="Password" class="form-label text-muted">Password</label>
                            <input asp-for="Password" type="password" class="form-control bg-dark text-light border-secondary" placeholder="Enter password" required />
                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>
                        
                        <div class="d-grid mt-4">
                            <button type="submit" class="btn btn-primary btn-lg"><i class="fa-solid fa-right-to-bracket"></i> Login</button>
                        </div>
                    </form>
                </div>
                <div class="card-footer text-center py-3 border-top border-secondary">
                    <div class="small"><a asp-page="/Index" class="text-info">Return to Website</a></div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
