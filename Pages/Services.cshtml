@page
@model PersonalWebSite.Pages.ServicesModel
@{
    ViewData["Title"] = "Skills & Services";
}

<div class="text-center my-5">
    <h2>My Skills & Services</h2>
    <p class="text-muted">Designed using Bootstrap cards and JS animations.</p>
</div>

<div class="row g-4 mb-5">
    <!-- Frontend Card -->
    <div class="col-md-4">
        <div class="card h-100 custom-card text-center p-3 bg-dark border border-secondary text-light">
            <div class="card-body">
                <i class="fa-brands fa-html5 fa-3x text-danger mb-3"></i>
                <h5 class="card-title">Frontend Development</h5>
                <p class="card-text">I develop modern and responsive interfaces using HTML5, CSS3, JavaScript, and Bootstrap 5.</p>
                <button class="btn btn-outline-primary" onclick="toggleElement('frontendDetails')">Show Details</button>
                <div id="frontendDetails" class="mt-3 text-start" style="display:none;">
                    <strong>Skill Level:</strong>
                    <div class="progress mt-2 bg-secondary">
                        <div class="progress-bar bg-success" role="progressbar" style="width: 0%;" aria-valuenow="90" aria-valuemin="0" aria-valuemax="100">90%</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Backend Card -->
    <div class="col-md-4">
        <div class="card h-100 custom-card text-center p-3 bg-dark border border-secondary text-light">
            <div class="card-body">
                <i class="fa-solid fa-server fa-3x text-info mb-3"></i>
                <h5 class="card-title">Backend Development</h5>
                <p class="card-text">I build powerful, secure, and scalable server-side applications with C# and ASP.NET Core.</p>
                <button class="btn btn-outline-primary" onclick="toggleElement('backendDetails')">Show Details</button>
                <div id="backendDetails" class="mt-3 text-start" style="display:none;">
                    <strong>Skill Level:</strong>
                    <div class="progress mt-2 bg-secondary">
                        <div class="progress-bar bg-info" role="progressbar" style="width: 0%;" aria-valuenow="85" aria-valuemin="0" aria-valuemax="100">85%</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Database Card -->
    <div class="col-md-4">
        <div class="card h-100 custom-card text-center p-3 bg-dark border border-secondary text-light">
            <div class="card-body">
                <i class="fa-solid fa-database fa-3x text-warning mb-3"></i>
                <h5 class="card-title">Database Management</h5>
                <p class="card-text">I perform data modeling with SQLite and SQL Server, using Entity Framework Core for data management.</p>
                <button class="btn btn-outline-primary" onclick="toggleElement('dbDetails')">Show Details</button>
                <div id="dbDetails" class="mt-3 text-start" style="display:none;">
                    <strong>Skill Level:</strong>
                    <div class="progress mt-2 bg-secondary">
                        <div class="progress-bar bg-warning" role="progressbar" style="width: 0%;" aria-valuenow="80" aria-valuemin="0" aria-valuemax="100">80%</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
