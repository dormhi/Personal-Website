@page
@model PersonalWebSite.Pages.GalleryModel
@{
    ViewData["Title"] = "Portfolio";
}

<div class="text-center my-5">
    <h2>My Projects & GitHub Repositories</h2>
    <p class="text-muted">Showcasing my works using Bootstrap Carousel and Grid.</p>
</div>

<div class="row justify-content-center">
    <div class="col-md-8">
        <div id="portfolioCarousel" class="carousel slide" data-bs-ride="carousel">
            <div class="carousel-indicators">
                <button type="button" data-bs-target="#portfolioCarousel" data-bs-slide-to="0" class="active" aria-current="true" aria-label="Slide 1"></button>
                <button type="button" data-bs-target="#portfolioCarousel" data-bs-slide-to="1" aria-label="Slide 2"></button>
                <button type="button" data-bs-target="#portfolioCarousel" data-bs-slide-to="2" aria-label="Slide 3"></button>
            </div>
            <div class="carousel-inner shadow-lg rounded border border-secondary">
                <div class="carousel-item active">
                    <img src="https://picsum.photos/800/400?random=1" class="d-block w-100 opacity-50" alt="Project 1">
                    <div class="carousel-caption d-none d-md-block bg-dark bg-opacity-75 rounded p-3">
                        <h5><i class="fa-brands fa-github"></i> CargallerySAD</h5>
                        <p>SAD project and first big website (JavaScript)</p>
                        <a href="https://github.com/dormhi/CargallerySAD" target="_blank" class="btn btn-sm btn-outline-light mt-2">View on GitHub</a>
                    </div>
                </div>
                <div class="carousel-item">
                    <img src="https://picsum.photos/800/400?random=2" class="d-block w-100 opacity-50" alt="Project 2">
                    <div class="carousel-caption d-none d-md-block bg-dark bg-opacity-75 rounded p-3">
                        <h5><i class="fa-brands fa-github"></i> dormhiQuizzer</h5>
                        <p>Simple Java project quiz management system for Object Oriented Programming course.</p>
                        <a href="https://github.com/dormhi/dormhiQuizzer" target="_blank" class="btn btn-sm btn-outline-light mt-2">View on GitHub</a>
                    </div>
                </div>
                <div class="carousel-item">
                    <img src="https://picsum.photos/800/400?random=3" class="d-block w-100 opacity-50" alt="Project 3">
                    <div class="carousel-caption d-none d-md-block bg-dark bg-opacity-75 rounded p-3">
                        <h5><i class="fa-brands fa-github"></i> syncbreaker</h5>
                        <p>A JavaScript based project.</p>
                        <a href="https://github.com/dormhi/syncbreaker" target="_blank" class="btn btn-sm btn-outline-light mt-2">View on GitHub</a>
                    </div>
                </div>
            </div>
            <button class="carousel-control-prev" type="button" data-bs-target="#portfolioCarousel" data-bs-slide="prev">
                <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Previous</span>
            </button>
            <button class="carousel-control-next" type="button" data-bs-target="#portfolioCarousel" data-bs-slide="next">
                <span class="carousel-control-next-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Next</span>
            </button>
        </div>
    </div>
</div>

<div class="row mt-5 g-4">
    <div class="col-12 text-center mb-3">
        <h3>All GitHub Repositories</h3>
    </div>
    
    <!-- Repo 1 -->
    <div class="col-md-4">
        <div class="card h-100 bg-dark border border-secondary text-light custom-card">
            <div class="card-body">
                <h5 class="card-title text-primary"><i class="fa-brands fa-github"></i> CargallerySAD</h5>
                <h6 class="card-subtitle mb-2 text-muted">JavaScript</h6>
                <p class="card-text">SAD project and first big website</p>
                <a href="https://github.com/dormhi/CargallerySAD" target="_blank" class="card-link text-info">Repo Link</a>
            </div>
        </div>
    </div>
    
    <!-- Repo 2 -->
    <div class="col-md-4">
        <div class="card h-100 bg-dark border border-secondary text-light custom-card">
            <div class="card-body">
                <h5 class="card-title text-primary"><i class="fa-brands fa-github"></i> dormhi</h5>
                <h6 class="card-subtitle mb-2 text-muted">Profile Repo</h6>
                <p class="card-text">About me</p>
                <a href="https://github.com/dormhi/dormhi" target="_blank" class="card-link text-info">Repo Link</a>
            </div>
        </div>
    </div>
    
    <!-- Repo 3 -->
    <div class="col-md-4">
        <div class="card h-100 bg-dark border border-secondary text-light custom-card">
            <div class="card-body">
                <h5 class="card-title text-primary"><i class="fa-brands fa-github"></i> dormhiQuizzer</h5>
                <h6 class="card-subtitle mb-2 text-muted">Java</h6>
                <p class="card-text">Simple Java project quiz management system for Object Oriented Programming course.</p>
                <a href="https://github.com/dormhi/dormhiQuizzer" target="_blank" class="card-link text-info">Repo Link</a>
            </div>
        </div>
    </div>
    
    <!-- Repo 4 -->
    <div class="col-md-4">
        <div class="card h-100 bg-dark border border-secondary text-light custom-card">
            <div class="card-body">
                <h5 class="card-title text-primary"><i class="fa-brands fa-github"></i> gradecalculator</h5>
                <h6 class="card-subtitle mb-2 text-muted">Java</h6>
                <p class="card-text">java based simple ui project</p>
                <a href="https://github.com/dormhi/gradecalculator" target="_blank" class="card-link text-info">Repo Link</a>
            </div>
        </div>
    </div>
    
    <!-- Repo 5 -->
    <div class="col-md-4">
        <div class="card h-100 bg-dark border border-secondary text-light custom-card">
            <div class="card-body">
                <h5 class="card-title text-primary"><i class="fa-brands fa-github"></i> syncbreaker</h5>
                <h6 class="card-subtitle mb-2 text-muted">JavaScript</h6>
                <p class="card-text">A syncbreaker application.</p>
                <a href="https://github.com/dormhi/syncbreaker" target="_blank" class="card-link text-info">Repo Link</a>
            </div>
        </div>
    </div>
</div>
